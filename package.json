{
  "name": "lovelace-shutter-card",
  "version": "0.0.1",
  "description": "Home Assistant Lovelace card for controlling European-style roller shutters with configurable slat positions",
  "type": "module",
  "main": "dist/lovelace-shutter-card.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "shutter",
    "roller-shutter",
    "jalousie",
    "hacs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "home-assistant-js-websocket": "^9.4.0",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@mdi/js": "^7.4.47",
    "@storybook/web-components-vite": "^10",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^8.57.1",
    "eslint-plugin-lit": "^1.15.0",
    "eslint-plugin-wc": "^2.2.0",
    "prettier": "^3.5.3",
    "storybook": "^10",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
